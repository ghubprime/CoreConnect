@using CoreConnect.Shared.Models
@using CoreConnect.Shared.Entities
@using Microsoft.AspNetCore.Components.Server.Circuits
@using Bitbound.SimpleMessenger
@using CoreConnect.Server.Models.Messages

@inject IMessenger Messenger
@inject CoreConnect.Server.Services.IAgentHubSessionCache AgentHubSessionCache
@inject Microsoft.AspNetCore.SignalR.IHubContext<CoreConnect.Server.Hubs.AgentHub, CoreConnect.Shared.Interfaces.IAgentHubClient> AgentHubContext

@inherits CoreConnect.Server.Components.MessengerSubscriber

<div class="py-3">
    @if (!Device.IsOnline)
    {
        <h5 class="text-center mt-5">Device must be online to retrieve processes.</h5>
    }
    else
    {
        <div class="mb-3 d-flex justify-content-between align-items-center">
            <div>
                <button class="btn btn-primary" @onclick="Refresh" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Loading...</span>
                    }
                    else
                    {
                        <span>Refresh</span>
                    }
                </button>
            </div>
            
            <div class="input-group" style="max-width: 300px;">
                <input type="text" class="form-control" placeholder="Search processes..." @bind="_filterText" @bind:event="oninput" />
            </div>
        </div>

        @if (_isLoading && _processes.Count == 0)
        {
            <div class="text-center mt-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (_filteredProcesses.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mt-3">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Memory (MB)</th>
                            <th>Main Window Title</th>
                            <th>Session ID</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var proc in _filteredProcesses)
                        {
                            <tr @key="proc.Id">
                                <td>@proc.Id</td>
                                <td>@proc.Name</td>
                                <td>@((proc.WorkingSetBytes / 1024 / 1024).ToString("N1"))</td>
                                <td>@proc.MainWindowTitle</td>
                                <td>@proc.SessionId</td>
                                <td>
                                    <button class="btn btn-sm btn-danger" @onclick="() => KillProcess(proc)">Kill</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="text-muted small mt-2">
                Showing @_filteredProcesses.Count of @_processes.Count total processes.
                @if (_isLoading)
                {
                    <span class="text-primary ms-2"><span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Streaming data...</span>
                }
            </div>
        }
        else if (!_isLoading)
        {
            <div class="alert alert-info mt-3">No processes found.</div>
        }
    }
</div>

@code {
    [Parameter]
    public Device Device { get; set; } = null!;

    [CascadingParameter]
    public Circuit Connection { get; set; } = null!;

    private List<ProcessInfo> _processes = new();
    private bool _isLoading = false;
    private string _filterText = "";
    private IDisposable? _messengerRegistration;

    private List<ProcessInfo> _filteredProcesses => string.IsNullOrWhiteSpace(_filterText)
        ? _processes
        : _processes.Where(p => 
            p.Name.Contains(_filterText, StringComparison.OrdinalIgnoreCase) ||
            p.MainWindowTitle.Contains(_filterText, StringComparison.OrdinalIgnoreCase) ||
            p.Id.ToString() == _filterText
          ).ToList();

    protected override async Task OnInitializedAsync()
    {
        RegistrationCallback<StreamReceivedMessage<ProcessInfo>> handler = async (sender, msg) =>
        {
            await foreach (var proc in msg.Stream)
            {
                _processes.Add(proc);
                await InvokeAsync(StateHasChanged); // Render incrementally as chunks arrive
            }
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        };

        await base.Register(Connection.Id, handler);
    }

    protected override void OnParametersSet()
    {
        if (Device != null && Device.IsOnline && _processes.Count == 0 && !_isLoading)
        {
            _ = Refresh();
        }
    }

    private async Task Refresh()
    {
        if (Device is null || !Device.IsOnline) return;

        _isLoading = true;
        _processes.Clear();
        StateHasChanged();

        var agentConnections = AgentHubSessionCache.GetConnectionIdsByDeviceIds(new[] { Device.ID });
        if (agentConnections.Any())
        {
            await AgentHubContext.Clients.Client(agentConnections.First())
                .GetProcesses(Connection.Id);
            return;
        }
        
        _isLoading = false;
    }

    private async Task KillProcess(ProcessInfo process)
    {
        var agentConnections = AgentHubSessionCache.GetConnectionIdsByDeviceIds(new[] { Device.ID });
        if (agentConnections.Any())
        {
            await AgentHubContext.Clients.Client(agentConnections.First())
                .KillProcess(process.Id);
                
            // Optional: Optimistically remove from UI or wait for next refresh
            _processes.RemoveAll(p => p.Id == process.Id);
        }
    }

    public new void Dispose()
    {
        base.Dispose();
    }
}
