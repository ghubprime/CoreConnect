@using CoreConnect.Shared.Models
@using CoreConnect.Shared.Entities
@using Microsoft.AspNetCore.Components.Server.Circuits
@using Bitbound.SimpleMessenger
@using CoreConnect.Server.Models.Messages

@inject IMessenger Messenger
@inject CoreConnect.Server.Services.IAgentHubSessionCache AgentHubSessionCache
@inject Microsoft.AspNetCore.SignalR.IHubContext<CoreConnect.Server.Hubs.AgentHub, CoreConnect.Shared.Interfaces.IAgentHubClient> AgentHubContext

@inherits CoreConnect.Server.Components.MessengerSubscriber

<div class="py-3">
    @if (!Device.IsOnline)
    {
        <h5 class="text-center mt-5">Device must be online to retrieve services.</h5>
    }
    else
    {
        <div class="mb-3 d-flex justify-content-between align-items-center">
            <div>
                <button class="btn btn-primary" @onclick="Refresh" disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Loading...</span>
                    }
                    else
                    {
                        <span>Refresh</span>
                    }
                </button>
            </div>
            
            <div class="input-group" style="max-width: 300px;">
                <input type="text" class="form-control" placeholder="Search services..." @bind="_filterText" @bind:event="oninput" />
            </div>
        </div>

        @if (_isLoading && _services.Count == 0)
        {
            <div class="text-center mt-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (_filteredServices.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mt-3">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Display Name</th>
                            <th>Status</th>
                            <th>Start Type</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var svc in _filteredServices)
                        {
                            <tr @key="svc.Name">
                                <td>@svc.Name</td>
                                <td>@svc.DisplayName</td>
                                <td>
                                    <span class="badge @(svc.Status == "Running" ? "bg-success" : (svc.Status == "Stopped" ? "bg-secondary" : "bg-warning"))">
                                        @svc.Status
                                    </span>
                                </td>
                                <td>@svc.StartType</td>
                                <td>
                                    <button class="btn btn-sm btn-warning" @onclick="() => RestartService(svc)">Restart</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="text-muted small mt-2">
                Showing @_filteredServices.Count of @_services.Count total services.
                @if (_isLoading)
                {
                    <span class="text-primary ms-2"><span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Streaming data...</span>
                }
            </div>
        }
        else if (!_isLoading)
        {
            <div class="alert alert-info mt-3">No services found.</div>
        }
    }
</div>

@code {
    [Parameter]
    public Device Device { get; set; } = null!;

    [CascadingParameter]
    public Circuit Connection { get; set; } = null!;

    private List<ServiceInfo> _services = new();
    private bool _isLoading = false;
    private string _filterText = "";
    private IDisposable? _messengerRegistration;

    private List<ServiceInfo> _filteredServices => string.IsNullOrWhiteSpace(_filterText)
        ? _services
        : _services.Where(s => 
            s.Name.Contains(_filterText, StringComparison.OrdinalIgnoreCase) ||
            s.DisplayName.Contains(_filterText, StringComparison.OrdinalIgnoreCase)
          ).ToList();

    protected override async Task OnInitializedAsync()
    {
        RegistrationCallback<StreamReceivedMessage<ServiceInfo>> handler = async (sender, msg) =>
        {
            await foreach (var svc in msg.Stream)
            {
                _services.Add(svc);
                await InvokeAsync(StateHasChanged); // Render incrementally as chunks arrive
            }
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        };

        await base.Register(Connection.Id, handler);
    }

    protected override void OnParametersSet()
    {
        if (Device != null && Device.IsOnline && _services.Count == 0 && !_isLoading)
        {
            _ = Refresh();
        }
    }

    private async Task Refresh()
    {
        if (Device is null || !Device.IsOnline) return;

        _isLoading = true;
        _services.Clear();
        StateHasChanged();

        var agentConnections = AgentHubSessionCache.GetConnectionIdsByDeviceIds(new[] { Device.ID });
        if (agentConnections.Any())
        {
            await AgentHubContext.Clients.Client(agentConnections.First())
                .GetServices(Connection.Id);
            return;
        }
        
        _isLoading = false;
    }

    private async Task RestartService(ServiceInfo service)
    {
        var agentConnections = AgentHubSessionCache.GetConnectionIdsByDeviceIds(new[] { Device.ID });
        if (agentConnections.Any())
        {
            await AgentHubContext.Clients.Client(agentConnections.First())
                .RestartService(service.Name);
        }
    }

    public new void Dispose()
    {
        base.Dispose();
    }
}
